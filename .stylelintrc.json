{
  "extends": ["stylelint-config-standard"],
  "ignoreFiles": [
    "dist/**/*",
    "node_modules/**/*",
    "src-tauri/**/*",
    "src/styles/base.css",
    "src/styles/setup.css"
  ],
  "rules": {
    "no-descending-specificity": null,
    "selector-class-pattern": null,
    "custom-property-pattern": null,
    "alpha-value-notation": null,
    "color-function-notation": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "no-duplicate-selectors": null,
    "media-feature-range-notation": null,
    "at-rule-empty-line-before": null,
    "declaration-empty-line-before": null,
    "rule-empty-line-before": null,
    "comment-empty-line-before": null,
    "no-empty-source": null,
    "declaration-property-value-disallowed-list": [
      {
        "/^color$|^background$|^background-color$|^border-color$|^border-top-color$|^border-bottom-color$|^border-left-color$|^border-right-color$/": [
          "/#[0-9a-fA-F]{3,8}/"
        ],
        "z-index": ["/^-?[0-9]+$/"]
      },
      {
        "message": "Use design tokens from src/styles/base.css (var(--accent), var(--z-modal), etc.) instead of raw values.",
        "severity": "warning"
      }
    ]
  }
}
