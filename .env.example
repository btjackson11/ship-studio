# Ship Studio environment variables
# Copy to `.env` for local overrides. None are required for normal development.

# Frontend log level. Accepted: debug | info | warn | error (default: info)
VITE_LOG_LEVEL=info

# Rust backtrace on panic. Accepted: 0 | 1 | full (default: 0)
RUST_BACKTRACE=0

# Rust tracing filter. Examples: info, debug, ship_studio=debug,hyper=warn
# See https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
RUST_LOG=info

# Force the onboarding wizard to appear on launch (real system checks).
# Accepted: 1 | unset. See CLAUDE.md → Onboarding / Setup Wizard Testing.
SHIPSTUDIO_FORCE_ONBOARDING=

# Force a specific mocked setup state. Accepted values:
#   fresh | auth-only | almost-done | both-agents | codex-only
# or a comma-separated list of ready items (e.g. homebrew,node,git,gh,gh_auth).
# See CLAUDE.md → Mock Mode for details.
SHIPSTUDIO_FORCE_SETUP=
