{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "opener:default",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "pty:default",
    "screenshots:default",
    "fs:default",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$RESOURCE/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/.nvm/versions/node" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/.nvm/**" }
      ]
    }
  ]
}
